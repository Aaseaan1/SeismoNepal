{
  "expo": {
    "name": "SeismoNep",
    "slug": "SeismoNep",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "seismonep",
    "extra": {
      "eas": {
        "projectId": "117eee0d-eaef-4ee3-8f57-d6441cc39248"
      }
    },
    "plugins": [
      "expo-router"
    ],
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "117eee0d-eaef-4ee3-8f57-d6441cc39248"
      }
    },
    "owner": "aaseaan1"
  }
}
