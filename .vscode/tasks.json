{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Backend",
      "type": "shell",
      "command": "cd \"${workspaceFolder}/backend\" && .venv/bin/python manage.py runserver 0.0.0.0:8000",
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Start Mobile App",
      "type": "shell",
      "command": "cd \"${workspaceFolder}/frontend-mobile\" && npm start",
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Start All",
      "dependsOn": [
        "Start Backend",
        "Start Mobile App"
      ],
      "dependsOrder": "parallel",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    }
  ]
}